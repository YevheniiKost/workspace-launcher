<Window x:Class="WorkspaceLauncher.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Settings"
        Height="340" Width="480"
        ResizeMode="NoResize"
        Style="{StaticResource DarkWindowStyle}"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Settings"
                   FontSize="20"
                   FontFamily="Segoe UI Semibold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,20"/>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="20">
            <StackPanel>

                <!-- Run on startup -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                    <CheckBox IsChecked="{Binding RunOnStartup}"
                              Style="{StaticResource DarkCheckBoxStyle}"
                              Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="Run on Windows startup"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="14"/>
                        <TextBlock Text="Adds WorkspaceLauncher to Windows startup"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,12"/>

                <!-- Start minimized -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                    <CheckBox IsChecked="{Binding StartMinimized}"
                              Style="{StaticResource DarkCheckBoxStyle}"
                              Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="Start minimized"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="14"/>
                        <TextBlock Text="Hide to system tray on startup"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,12"/>

                <!-- Auto-launch profile -->
                <StackPanel>
                    <TextBlock Text="Auto-launch profile on startup"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="14"
                               Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding ProfileItems}"
                              SelectedItem="{Binding SelectedAutoLaunchProfile}"
                              Style="{StaticResource DarkComboBoxStyle}"
                              DisplayMemberPath="Name"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Cancel"
                    Style="{StaticResource SecondaryButtonStyle}"
                    IsCancel="True"
                    Click="Cancel_Click"
                    Margin="0,0,8,0"/>
            <Button Content="Save"
                    Style="{StaticResource PrimaryButtonStyle}"
                    IsDefault="True"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
