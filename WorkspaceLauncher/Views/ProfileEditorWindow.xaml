<Window x:Class="WorkspaceLauncher.Views.ProfileEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:WorkspaceLauncher.ViewModels"
        xmlns:conv="clr-namespace:WorkspaceLauncher.Converters"
        xmlns:models="clr-namespace:WorkspaceLauncher.Models;assembly=WorkspaceLauncher.Core"
        mc:Ignorable="d"
        Title="Edit Profile"
        Height="580" Width="820"
        MinWidth="700" MinHeight="450"
        Style="{StaticResource DarkWindowStyle}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <conv:HexColorToBrushConverter x:Key="HexColorToBrush"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <ObjectDataProvider x:Key="ItemTypeValues"
                            MethodName="GetValues"
                            ObjectType="{x:Type models:ItemType}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:ItemType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Profile Metadata -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Profile Details" Style="{StaticResource SectionHeaderStyle}"/>

                <!-- Name -->
                <TextBlock Text="Name" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DarkTextBoxStyle}"
                         Margin="0,0,0,12"/>

                <!-- Color Palette -->
                <TextBlock Text="Accent Color" Style="{StaticResource LabelStyle}"/>
                <ItemsControl ItemsSource="{Binding Palette}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="32" Height="32" Margin="4"
                                    CornerRadius="16"
                                    Background="{Binding ., Converter={StaticResource HexColorToBrush}}"
                                    Cursor="Hand">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.SelectedColor, RelativeSource={RelativeSource AncestorType=Window}}"
                                                         Value="{Binding .}">
                                                <Setter Property="BorderBrush" Value="White"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.SelectColorCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding .}"/>
                                </Border.InputBindings>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Icon -->
                <TextBlock Text="Icon (emoji or .ico path)" Style="{StaticResource LabelStyle}" Margin="0,12,0,4"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox Text="{Binding IconPath, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBoxStyle}"
                             Width="200"
                             Margin="0,0,8,0"/>
                    <Button Content="&#x1F4C2; Browse .ico"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding BrowseIconCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Items Header -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="Launch Items"
                       Style="{StaticResource SectionHeaderStyle}"
                       VerticalAlignment="Center"/>
            <Button Content="+ Add Item"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalAlignment="Right"
                    Command="{Binding AddItemCommand}"/>
        </Grid>

        <!-- Items List -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:LaunchItemViewModel}">
                            <Border Background="{StaticResource Surface2Brush}"
                                    CornerRadius="8"
                                    Margin="4"
                                    Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="32"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Type ComboBox -->
                                    <ComboBox Grid.Column="0"
                                              ItemsSource="{Binding Source={StaticResource ItemTypeValues}}"
                                              SelectedItem="{Binding Type}"
                                              Style="{StaticResource DarkComboBoxStyle}"
                                              Margin="0,0,6,0"/>

                                    <!-- Path TextBox -->
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource DarkTextBoxStyle}"
                                             Margin="0,0,4,0"/>

                                    <!-- Browse Button -->
                                    <Button Grid.Column="2"
                                            Content="&#x1F4C2;"
                                            Style="{StaticResource IconButtonStyle}"
                                            Command="{Binding DataContext.BrowseItemPathCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Margin="0,0,6,0"
                                            ToolTip="Browse"/>

                                    <!-- Delay TextBox -->
                                    <StackPanel Grid.Column="3" Margin="0,0,6,0">
                                        <TextBlock Text="Delay (ms)" Style="{StaticResource LabelStyle}" FontSize="10"/>
                                        <TextBox Text="{Binding DelayMs, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource DarkTextBoxStyle}"/>
                                    </StackPanel>

                                    <!-- Close on end CheckBox -->
                                    <StackPanel Grid.Column="4" Margin="0,0,6,0" VerticalAlignment="Center">
                                        <TextBlock Text="Close on end" Style="{StaticResource LabelStyle}" FontSize="10"/>
                                        <CheckBox IsChecked="{Binding CloseOnSessionEnd}"
                                                  Style="{StaticResource DarkCheckBoxStyle}"
                                                  HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Delete Button -->
                                    <Button Grid.Column="5"
                                            Content="&#x1F5D1;"
                                            Style="{StaticResource DangerButtonStyle}"
                                            Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Padding="4"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Cancel"
                    Style="{StaticResource SecondaryButtonStyle}"
                    IsCancel="True"
                    Click="Cancel_Click"
                    Margin="0,0,8,0"/>
            <Button Content="Save"
                    Style="{StaticResource PrimaryButtonStyle}"
                    IsDefault="True"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
